<?xml version="1.0" encoding="UTF-8"?>
<ДатсСол_Канон Версия="Правил" Язык="Русь">
  <!-- 天：Мета -->
  <Верховный_Раздел Название="Общее_Предназначение">
    <Наименование>Суть: ДатсСол</Наименование>
    <Дао>
      Состязание многих сил в преображении мёртвой земли в сеть живых оазисов;
      попутно — мешать другим, иль самому терпеть помехи.
    </Дао>
    <Заповедь>
      Мультиаккаунты — тьма; употребляющий их подлежит изгнанию без предупреждения.
      Где слово писания расходится с деянием сервера — вера к серверу.
      Организаторы вправе изменять баланс, уточнять каноны, исправлять ошибки.
    </Заповедь>
  </Верховный_Раздел>

  <!-- 道：Цель -->
  <Высший_Принцип Название="Путь_Победы">
    <Раунд Длина="600 ходов" Единица="1 секунда" Сброс="полный"/>
    <Начисление>
      По завершении раунда заработанные баллы кумулируются в общий зачёт;
      именно сумма всех раундов и определяет победителя.
    </Начисление>
    <Критерии>
      <Первый>Набрать очков больше всех</Первый>
      <Второй>При равенстве — утратить меньше плантаций</Второй>
      <Третий>При равенстве — истребить более логов бобров</Третий>
      <Четвёртый>При равенстве — совершить более диверсий</Четвёртый>
    </Критерии>
    <Участие Активен="тот, кто терраформировал не менее 2 клеток как минимум в половине финальных раундов"/>
  </Высший_Принцип>

  <!-- 地：Мир -->
  <Раздел_Пространства Название="Земля_и_Клетки">
    <Плоскость>XY; бескрайня, но измерима</Плоскость>
    <Клетки>
      <Пустыня>
        Подданная; годна к терраформированию и основанию.
      </Пустыня>
      <Гора>
        Непреклонна; ни терраформировать, ни строить на ней нельзя.
      </Гора>
    </Клетки>
  </Раздел_Пространства>

  <!-- 时：Время -->
  <Раздел_Времени Название="Ходы_и_Раунды">
    <Ход>
      Минимальная единица бытия; в его теченье игрок ведает миром и отдаёт повеления.
      По исходе — наступает фаза обработки.
    </Ход>
    <Раунд Продолжительность="600 ходов">
      После сего весь прогресс развития тлеет; игрок возрождается с нуля,
      но апгрейды прежние с ним пребывают, и баллы — в зачёте.
    </Раунд>
  </Раздел_Времени>

  <!-- 物：Сущности -->
  <Раздел_Сущностей Название="Обитатели_Мира">
    <Плантации Лимит="30">
      <Сущность>
        Каждый владеет одним Центром Управления (ЦУ), водруженным на окраине.
        Под властью игрока; терраформируют клетку под собою, рождая оазис.
      </Сущность>

      <ЦУ>
        <Звание>Сердце сети; координирует всех</Звание>
        <Терраформация>Да, как и обычная плантация</Терраформация>
        <Перенос>
          Функции передаются иной прилегающей плантации;
          на прежнем месте остаётся обычная плантация; HP не изменяются.
        </Перенос>
        <Утрата>
          Если ЦУ погибает — вся сеть рушится; игрок возрождается на окраине.
          Штраф: 5% текущих очков (округление вниз, но не менее 1).
          Апгрейды прежние сохраняются.
        </Утрата>
      </ЦУ>

      <Связность>
        Власть простирается только по цепи смежных клеток от ЦУ;
        диагональ — не путь. Утратив связь, плантация становится потерянной.
      </Связность>

      <Потерянная>
        Не ведает повелений; прежняя команда угасает.
        Терраформирует клетку, но без очков; гибнет, теряя HP равное DS за ход.
        В лимите плантаций по-прежнему числится.
        Восстановив связь — вновь оживает.
      </Потерянная>
    </Плантации>

    <Бобры>
      <Логово HP="100" Регенерация="5">
        Не любит чужаков; каждый ход кружит руины,
        нанося 15 урона всем плантациям в радиусе 2, включая недостроенные.
      </Логово>
      <Награда Уничтожение="10-кратное от клеточной стоимости"/>
    </Бобры>

    <Катаклизмы>
      <Буря Возникновение="0.10" Формирование="5 ходов" Урон="2" Скорость="5-15">
        Движется по диагонали, через центр;
        не убивает, но доводит HP до 1;
        пока формируется — безвредна.
      </Буря>
      <Землетрясение Возникновение="0.05" Урон="10">
        Мгновенно трясёт все плантации и постройки.
        Если убило — никто не получает очков за диверсии, совершённые ранее.
      </Землетрясение>
    </Катаклизмы>
  </Раздел_Сущностей>

  <!-- 体：Тело плантации -->
  <Раздел_Тела Название="Характеристики_Плантации">
    <HP Текущее="—" Максимальное="MHP" Базовое="50">Здоровье</HP>
    <TS Базовое="5">Скорость терраформирования; % за ход</TS>
    <CS Базовое="5">Скорость строительства новой плантации</CS>
    <RS Базовое="5">Скорость ремонта иных плантаций</RS>
    <SE Базовое="5">Эффективность диверсий на чужом</SE>
    <BE Базовое="5">Эффективность уничтожения логов бобров</BE>
    <DS Базовое="10">Скорость деградации без связи и недостроенных</DS>
    <AR Базовое="2">Радиус выполнения команды</AR>
    <SR Базовое="3">Радиус выбора выходной точки</SR>
    <VR Базовое="3">Радиус обзора</VR>
    <Примечание>
      Все радиусы — квадратные: |ΔX| ≤ R и |ΔY| ≤ R;
      зона центрирована на плантации.
    </Примечание>
  </Раздел_Тела>

  <!-- 法：Действия -->
  <Раздел_Действий Название="Четыре_Искусства_и_Прочее">
    <Автоматическое>
      Всякая плантация, включая ЦУ, непрестанно терраформирует клетку под собою,
      прибавляя TS к прогрессу; повеления на сие не требуются.
    </Автоматическое>

    <Выбор_Одного>
      <Строительство>
        Воздвигает новую плантацию на пустой клетке в пределах AR.
        Можно привлечь многих; но всякая следующая команда через одну плантацию
        теряет 1 от CS, и вплоть до нуля.
        <Стройка Тип="Отдельный_юнит" Цель="50 HP">
          По достижении 50 HP — становится полноценной плантацией с MHP.
          Иммунитет 3 хода от вражьих действий, катаклизмов и бобров.
        </Стройка>
        <Коллизия>
          Если несколько игроков строят на одной клетке — у каждого свой прогресс.
          Кто раньше завершит — тому плантация.
          Если в одном ходу завершат несколько — весь прогресс обнуляется;
          придётся начинать сначала.
        </Коллизия>
        <Забвение>
          Если прогресса не было 1 ход — деградация по DS.
        </Забвение>
        <Лимит>
          Превысив лимит, древнейшая из завершённых исчезнет (возраст в ходах);
          при равенстве возраста — случайная.
          Опасно: так можно уничтожить собственное ЦУ.
        </Лимит>
        <Невозможность_Диверсии_На_Стройку>
          На строящуюся плантацию диверсию совершить нельзя;
          вместо сего происходит стройка своей по правилам коллизии.
        </Невозможность_Диверсии_На_Стройку>
      </Строительство>

      <Ремонт>
        Восстанавливает HP своей плантации на величину RS за ход.
        Нельзя чинить себя самого; иной плантацией подавать команду.
        Через выходную точку — с потерей 1 от RS за каждую следующую команду.
      </Ремонт>

      <Диверсия>
        Наносит чужой плантации урон SE за ход.
        Доведя до 0 — плантация погибает; диверсант получает очки,
        равные потенциальным очкам с клетки.
        <Last_Hit>
          Если несколько совершали диверсию — очки тому, кто в последний ход
          нанёс больший урон. При равенстве — делят поровну.
        </Last_Hit>
        <Сохранение>Прогресс терраформации клетки сохраняется.</Сохранение>
      </Диверсия>

      <Уничтожение_Бобров>
        Атака логова; каждая плантация наносит урон BE.
        Через выходную точку — с потерей 1 от BE за каждую следующую команду.
        <Last_Hit>
          Очки начисляются по правилу последнего удара:
          кто в финальный ход нанёс больший урон — тому десятикратная награда.
          При равенстве — делят поровну.
        </Last_Hit>
        <Последствие>Клетка остаётся готовой к терраформированию.</Последствие>
      </Уничтожение_Бобров>
    </Выбор_Одного>

    <Перенос_ЦУ>
      Формат: [[откуда], [куда]]; куда — прилегающая к ЦУ плантация.
      Совершается после диверсий в фазе обработки.
    </Перенос_ЦУ>

    <Апгрейд Интервал="30 ходов" МаксОчков="15">
      <Ветвь Название="repair_power" Макс="3">Сила ремонта и строительства +1</Ветвь>
      <Ветвь Название="max_hp" Макс="5">Максимальное здоровье +10</Ветвь>
      <Ветвь Название="settlement_limit" Макс="10">Лимит поселений +1</Ветвь>
      <Ветвь Название="signal_range" Макс="—">Дальность сигнала +1</Ветвь>
      <Ветвь Название="decay_mitigation" Макс="3">Скорость деградации -2; действует и на стройку</Ветвь>
      <Ветвь Название="earthquake_mitigation" Макс="3">Урон от землетрясений -2; действует и на стройку</Ветвь>
      <Ветвь Название="beaver_damage_mitigation" Макс="5">Урон от бобров -2; действует и на стройку</Ветвь>
      <Ветвь Название="vision_range" Макс="5">Радиус обзора +2</Ветвь>
    </Апгрейд>
  </Раздел_Действий>

  <!-- 序：Порядок -->
  <Раздел_Порядка Название="Фаза_Обработки_Сервера">
    <Пояснение>Внутри каждого этапа сервер проходит по всем юнитам.</Пояснение>
    <Фаза Порядок="1">Апгрейды плантаций</Фаза>
    <Фаза Порядок="2">Ремонт и Стройка</Фаза>
    <Фаза Порядок="3">Диверсии</Фаза>
    <Фаза Порядок="4">Атака по логову бобров</Фаза>
    <Фаза Порядок="5">Перенос ЦУ</Фаза>
    <Фаза Порядок="6">Атака бобров</Фаза>
    <Фаза Порядок="7">Деградация потерянных плантаций</Фаза>
    <Фаза Порядок="8">Урон по недостроенным без прогресса за 1 ход</Фаза>
    <Фаза Порядок="9">Терраформация и начисление очков</Фаза>
    <Фаза Порядок="10">Респавн игроков</Фаза>
    <Фаза Порядок="11">Обработка природных катаклизмов</Фаза>
    <Важность>
      Некоторые юниты могут не дойти до следующей фазы, если погибнут в текущей.
    </Важность>
  </Раздел_Порядка>

  <!-- 数：Числа и меры -->
  <Раздел_Чисел Название="Мерило_и_Воздаяние">
    <Терраформация>
      <Обычная_Клетка Очки_За_1процент="10" Максимум="1000"/>
      <Усиленная_Клетка Очки_За_1процент="15" Максимум="1500" Условие="X кратно 7 и Y кратно 7"/>
      <Завершение>При 100% плантация исчезает.</Завершение>
      <Долговечность После100="80 ходов" Деградация="10% за ход"/>
    </Терраформация>

    <Баллы_За_Место>
      <Место Номер="1" Баллы="150"/>
      <Место Номер="2" Баллы="114"/>
      <Место Номер="3" Баллы="89"/>
      <Место Номер="4" Баллы="69"/>
      <Место Номер="5" Баллы="58"/>
      <Место Номер="6" Баллы="50"/>
      <Место Номер="7" Баллы="44"/>
      <Место Номер="8-13" От="43" До="38"/>
      <Место Номер="14-25" От="37" До="26"/>
      <Место Номер="26-50" От="25" До="1"/>
      <Место Номер="51+" Баллы="1"/>
      <Условие>Минимум 1 балл, если в конце раунда очков больше 0.</Условие>
    </Баллы_За_Место>
  </Раздел_Чисел>

  <!-- 术：Техника взаимодействия -->
  <Раздел_Техники Название="Врата_API">
    <Авторизация Заголовок="X-Auth-Token"/>

    <Врата Название="Arena" Метод="GET" Путь="/api/arena">
      <Служение>Возвращает текущее состояние мира.</Служение>
    </Врата>

    <Врата Название="Command" Метод="POST" Путь="/api/command">
      <Служение>Отправляет повеления на текущий ход.</Служение>
      <Тело>
        <Команда Тип="path">Массив координат [автор, выходная_точка, цель]</Команда>
        <Тип_По_Цели>
          <Своя>Плантация — ремонт</Своя>
          <Чужая>Плантация — диверсия</Чужая>
          <Логово>Атака бобров</Логово>
          <Пустая>Строительство</Пустая>
        </Тип_По_Цели>
        <plantationUpgrade>Название апгрейда для покупки</plantationUpgrade>
        <relocateMain>[[отX, отY], [доX, доY]] — перенос ЦУ</relocateMain>
        <Условие>Хотя бы одно полезное действие обязательно.</Условие>
      </Тело>
    </Врата>

    <Врата Название="Logs" Метод="GET" Путь="/api/logs">
      <Служение>Возвращает игровые логи.</Служение>
      <Отказ>Если токен не зарегистрирован — ошибка регистрации.</Отказ>
    </Врата>
  </Раздел_Техники>
</ДатсСол_Канон>